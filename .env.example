# Copy to `.env` (`cp .env.example .env`) before bringing the stack up.
# These defaults work locally. Before deploying to a public VM, change the
# passwords below.

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_DB=ecommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/ecommerce

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_USER=ecommerce
RABBITMQ_PASS=changeme
RABBITMQ_URL=amqp://ecommerce:changeme@rabbitmq:5672/

# ─── Meilisearch (master key MUST be >=16 bytes in production mode) ──
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_API_KEY=masterKeyDevelopmentOnlyChangeMe

# ─── JWT (use `openssl rand -hex 32` for production) ────────
JWT_SECRET=dev-secret-please-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# ─── Observability ──────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_NAME=ecommerce-backend
